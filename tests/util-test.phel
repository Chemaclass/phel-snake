(ns phel-snake-tests\util-test
  (:require phel-snake\util :refer [get-int-arg])
  (:require phel\test :refer [deftest is]))

(deftest test-get-int-arg
  (is (= 10 (get-int-arg [] "key" 10)) "empty args results in default value")
  (is (= 10 (get-int-arg ["unknown=2"] "key" 10)) "unknown key results in default value")
  (is (= 5 (get-int-arg ["unknown=2" "key=5"] "key" 10)) "defined key results in defined value")
  (is (= 10 (get-int-arg ["prefix-key=5"] "key" 10)) "does not match on substring"))
