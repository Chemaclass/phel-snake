(ns phel-snake-tests\core\speed-test
  (:require phel-snake\core\speed :refer [compute-delay
                                          base-delay-us
                                          difficulty-scale])
  (:require phel\test :refer [deftest is]))

(def- variable-cfg {:variable-speed? true})
(def- fixed-cfg {:variable-speed? false})

(defn- snake [dir score] {:direction dir :score score})

(deftest test-compute-delay-accelerate-wins
  (is (= 0 (compute-delay (snake :right 0) variable-cfg 3 0))
      "positive accelerate-steps forces zero delay")
  (is (= 0 (compute-delay (snake :right 0) variable-cfg 3 5))
      "accelerate overrides slow-ticks"))

(deftest test-compute-delay-fixed-mode
  (is (= base-delay-us (compute-delay (snake :right 0) fixed-cfg 0 0))
      "non-variable mode = base delay"))

(deftest test-compute-delay-horizontal-halves
  (let [vert  (compute-delay (snake :up 0) variable-cfg 0 0)
        horiz (compute-delay (snake :right 0) variable-cfg 0 0)]
    (is (= base-delay-us vert) "vertical uses full base")
    (is (= (int (/ base-delay-us 2)) horiz) "horizontal halves delay")))

(deftest test-compute-delay-score-scales
  (let [d0 (compute-delay (snake :up 0) variable-cfg 0 0)
        d5 (compute-delay (snake :up 5) variable-cfg 0 0)]
    (is (= (- d0 (* 5 difficulty-scale)) d5) "each score point shaves difficulty-scale")))

(deftest test-compute-delay-slow-doubles
  (let [normal (compute-delay (snake :up 0) variable-cfg 0 0)
        slowed (compute-delay (snake :up 0) variable-cfg 0 10)]
    (is (= (* 2 normal) slowed) "slow-ticks doubles the base delay")))

(deftest test-compute-delay-score-clamped
  (let [huge (compute-delay (snake :up 1000) variable-cfg 0 0)]
    (is (>= huge 0) "delay never negative regardless of score")))
