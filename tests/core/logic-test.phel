(ns phel-snake-tests\core\logic-test
  (:require phel-snake\core\logic :refer [snake
                                          snake-reach-goal?
                                          move-snake
                                          collision-with-board?
                                          self-collision?
                                          wrap-head
                                          grow-snake
                                          advance-combo
                                          step-head])
  (:require phel\test :refer [deftest is]))

(deftest test-step-head
  (is (= {:x 6 :y 5} (step-head {:x 5 :y 5} :right)))
  (is (= {:x 4 :y 5} (step-head {:x 5 :y 5} :left)))
  (is (= {:x 5 :y 4} (step-head {:x 5 :y 5} :up)))
  (is (= {:x 5 :y 6} (step-head {:x 5 :y 5} :down))))

(deftest test-snake-reach-goal?
  (let [goal {:x 2 :y 2}]
    (is (false? (snake-reach-goal? {:head {:x 1 :y 1}} goal)))
    (is (true? (snake-reach-goal? {:head {:x 2 :y 2}} goal)))))

(deftest test-collision-with-board?
  (let [board {:width 10 :height 10}]
    (is (false? (collision-with-board? board {:head {:x 5 :y 5}})))
    (is (true?  (collision-with-board? board {:head {:x 5 :y 0}})) "collision on top")
    (is (true?  (collision-with-board? board {:head {:x 5 :y 9}})) "collision on bottom")
    (is (true?  (collision-with-board? board {:head {:x 10 :y 5}})) "collision on right")
    (is (true?  (collision-with-board? board {:head {:x 0 :y 5}})) "collision on left")))

(deftest test-move-snake
  (let  [s (snake :right 1 {:x 5 :y 5} [{:x 3 :y 5} {:x 4 :y 5}])]
    (is (= (snake :right 1 {:x 6 :y 5} [{:x 4 :y 5} {:x 5 :y 5}])
           (move-snake s nil)) "Keep the old direction if nil")
    (is (= (snake :left 1 {:x 4 :y 5} [{:x 4 :y 5} {:x 5 :y 5}])
           (move-snake s :left)))
    (is (= (snake :right 1 {:x 6 :y 5} [{:x 4 :y 5} {:x 5 :y 5}])
           (move-snake s :right)))
    (is (= (snake :up 1 {:x 5 :y 4} [{:x 4 :y 5} {:x 5 :y 5}])
           (move-snake s :up)))
    (is (= (snake :down 1 {:x 5 :y 6} [{:x 4 :y 5} {:x 5 :y 5}])
           (move-snake s :down)))))

(deftest test-grow-snake-right
  (is (= (snake :right 1 {:x 6 :y 5} [{:x 3 :y 5} {:x 4 :y 5} {:x 5 :y 5}])
         (grow-snake (snake :right 1 {:x 5 :y 5} [{:x 3 :y 5} {:x 4 :y 5}])))))

(deftest test-grow-snake-left
  (is (= (snake :left 1 {:x 4 :y 5} [{:x 3 :y 5} {:x 4 :y 5} {:x 5 :y 5}])
         (grow-snake (snake :left 1 {:x 5 :y 5} [{:x 3 :y 5} {:x 4 :y 5}])))))

(deftest test-grow-snake-up
  (is (= (snake :up 1 {:x 5 :y 4} [{:x 3 :y 5} {:x 4 :y 5} {:x 5 :y 5}])
         (grow-snake (snake :up 1 {:x 5 :y 5} [{:x 3 :y 5} {:x 4 :y 5}])))))

(deftest test-grow-snake-down
  (is (= (snake :down 1 {:x 5 :y 6} [{:x 3 :y 5} {:x 4 :y 5} {:x 5 :y 5}])
         (grow-snake (snake :down 1 {:x 5 :y 5} [{:x 3 :y 5} {:x 4 :y 5}])))))

(deftest test-self-collision?
  (is (false? (self-collision? (snake :right 0 {:x 5 :y 5} [])))
      "no tail => no self collision")
  (is (false? (self-collision? (snake :right 0 {:x 5 :y 5} [{:x 4 :y 5} {:x 3 :y 5}])))
      "head not on any tail cell")
  (is (true? (self-collision? (snake :right 0 {:x 3 :y 5} [{:x 4 :y 5} {:x 3 :y 5}])))
      "head overlaps tail cell"))

(deftest test-advance-combo
  (let [zero {:count 0 :ticks-left 0 :multiplier 1}
        first-eat (advance-combo zero true)]
    (is (= 1 (first-eat :count)) "first eat starts the combo")
    (is (= 1 (first-eat :multiplier)) "first eat has no multiplier")
    (let [second-eat (advance-combo first-eat true)]
      (is (= 2 (second-eat :count)) "second eat within window grows combo")
      (is (= 2 (second-eat :multiplier)) "x2 on second consecutive eat"))
    (let [ticked (advance-combo first-eat false)]
      (is (= 1 (ticked :count)) "combo persists while window is open")
      (is (= 1 (ticked :multiplier)) "no multiplier when not eating"))))

(deftest test-wrap-head
  (let [board {:width 10 :height 10}]
    (is (= {:x 5 :y 5}
           ((wrap-head board (snake :right 0 {:x 5 :y 5} [])) :head))
        "inside play area => unchanged")
    (is (= {:x 2 :y 5}
           ((wrap-head board (snake :right 0 {:x 10 :y 5} [])) :head))
        "crossed right wall => wraps to left edge")
    (is (= {:x 9 :y 5}
           ((wrap-head board (snake :left 0 {:x 1 :y 5} [])) :head))
        "crossed left wall => wraps to right edge")
    (is (= {:x 5 :y 1}
           ((wrap-head board (snake :down 0 {:x 5 :y 9} [])) :head))
        "crossed bottom wall => wraps to top")
    (is (= {:x 5 :y 8}
           ((wrap-head board (snake :up 0 {:x 5 :y 0} [])) :head))
        "crossed top wall => wraps to bottom")))
